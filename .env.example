# ── LLM API Keys ──────────────────────────────────────
# At least one of these is REQUIRED for the agent pipeline
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=                          # optional fallback

# ── Ollama (local LLM, optional) ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://caduser:cadpass@localhost:5432/caddb

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO Object Storage ──────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=cad-exports
MINIO_SECURE=false

# ── App Settings ──────────────────────────────────────
DEV_MODE=true
SECRET_KEY=change-this-in-production-to-a-random-string
MAX_RETRIES=5
CAD_TIMEOUT_SECONDS=60
MAX_ALTERNATIVES=5

# ── Frontend (Next.js) ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
